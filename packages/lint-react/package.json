{
  "name": "@ktam/lint-react",
  "version": "0.5.1",
  "description": "ESLint and Prettier configs for React projects",
  "keywords": [
    "eslint",
    "prettier",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kingston/ktam-tools"
  },
  "license": "MIT",
  "author": "Kingston Tam",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./eslint": "./eslint.config.react.js",
    "./eslint-astro": "./eslint.config.astro.js",
    "./eslint-react": "./eslint.config.react.js",
    "./eslint-configs/astro": "./eslint-configs/astro.js",
    "./eslint-configs/react": "./eslint-configs/react.js",
    "./eslint-configs/storybook": "./eslint-configs/storybook.js",
    "./eslint-configs/tailwind": "./eslint-configs/tailwind.js",
    "./prettier": "./prettier.config.react.js",
    "./prettier-astro": "./prettier.config.astro.js"
  },
  "files": [
    "eslint-configs",
    "eslint.config.astro.js",
    "eslint.config.react.js",
    "prettier.config.react.js",
    "prettier.config.astro.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint .",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier -w .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ktam/lint-node": "workspace:*",
    "@typescript-eslint/parser": "8.53.1",
    "eslint-plugin-astro": "1.5.0",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-storybook": "10.2.0",
    "globals": "^17.1.0",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "typescript-eslint": "8.53.1"
  },
  "devDependencies": {
    "@tsconfig/node20": "20.1.6",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@types/node": "24.5.2",
    "@typescript-eslint/utils": "8.44.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
